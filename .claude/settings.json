{
  "$comment": "Light-tier baseline (ai_project_v1 project template, deployed copy — canonical: _meta\\project-template). Hook blocks credential surfaces + irreversible deletes; outward actions (push/publish) are ASK, not deny — light projects push with user approval. Governed tier is opt-in: see _meta\\foundation.",
  "permissions": {
    "deny": [
      "Read(./secrets/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Write(./secrets/**)",
      "Write(**/.env)",
      "Bash(git filter-branch:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "PowerShell(git push:*)",
      "Bash(gh pr:*)",
      "Bash(gh release:*)",
      "Bash(npm publish:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(git commit --amend:*)",
      "Bash(git branch -D:*)",
      "Bash(git clean -f:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(yarn add:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(git remote add:*)",
      "Bash(kubectl:*)",
      "Bash(terraform apply:*)",
      "Bash(docker push:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": ".claude\\hooks\\floor_guard.cmd" }
        ]
      }
    ]
  }
}
